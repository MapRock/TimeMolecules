OPENAI_API_KEY="Your OpenAI API Key"
CYPHER_TEMPLATES_DIR="C:/MapRock/TimeMolecules/Cypher_Templates"
DATA_CATALOG_DIR="C:/MapRock/TimeMolecules/data_catalog"
SEMANTIC_WEB_DIR="C:/MapRock/TimeMolecules/semantic_web"
BOOK_CODE_DIR="C:/MapRock/TimeMolecules/book_code" # This is the directory where code in the book is stored.
BASE_DIR="C:/MapRock/TimeSolution/src/"
CYPHER_LOAD_DIR="C:/MapRock/Neo4j/relate-data/dbmss/<your neo4j dir>/import/"
DEFAULT_OUTPUT_DIR="C:/MapRock/TimeMolecules/demo_output/"
DEFAULT_INPUT_DIR="C:/MapRock/TimeMolecules/demo_input/"
QUERY_DIR="C:/MapRock/TimeMolecules/book_queries/"
# openai or ollama for embeddings. Ollama requires a local model that can do embeddings, such as nomic-embed-text. OpenAI uses the text-embedding-3-large model for embeddings.
LLM="ollama" 
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBED_MODEL='nomic-embed-text'
OLLAMA_CTX=32768
# ChatGPT settings. Be sure to use CHATGPT_MODEL for normal LLM communication.
CHATGPT_MODEL="gpt-4.1" # 4754 max tokens for this model.
CHATGPT_EMBEDDING_MODEL="text-embedding-3-large"
CHATGPT_MAX_RESPONSE_TOKENS=1000
# Neo4j settings
NEO4J_URI="bolt://localhost:7687"
NEO4J_User="Your Neo4j User Name"
NEO4J_Password="Your Neo4j Password"
# Kyvos settings
kyvos_uid="Your Kyvos User ID"
# If KYVOS_DSN is blank, that means KYVOS is not being used.
KYVOS_DSN="KyvosDSN"
KYVOS_CATALOG="Your Kyvos Folder"
# Sample databases.
AEI_RDB_SERVER_NAME="Your Desktop SQL Server Name"
ADVENTUREWORKS_SERVER_NAME="Your Desktop SQL Server Name"
ADVENTUREWORKS_DATABASE_NAME="AdventureWorksDW2017"
# TimeSolution database
TIMESOLUTION_SERVER_NAME="Your Desktop SQL Server Name"
TIMESOLUTION_DATABASE_NAME="TimeSolution"
TIMESOLUTION_EMBEDDINGS="C:/MapRock/TimeMolecules/demo_output/tm_embeddings.csv"
# FLAGS
DEBUG=True
USE_SQLALCHEMY="False"
# Settings for examples.
EMBEDDINGS_DIR="C:/MapRock/TimeMolecules/Embeddings/"
MEMBERS_TEMPLATE="C:/MapRock/TimeMolecules/Embeddings/members_template.csv"
MEMBERS_EMBEDDINGS="C:/MapRock/TimeMolecules/Embeddings/members.csv"
CYPHER_EMBEDDINGS="C:/MapRock/TimeMolecules/Embeddings/cypher_embeddings.csv"
SIMILARITY_TEMPLATE="C:/MapRock/TimeMolecules/demo_input/Objects_Source_1.csv"
SIMILARITY_EMBEDDINGS="C:/MapRock/TimeMolecules/demo_input/Objects_Source_1a.csv"
